{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/identity/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/identity" }]
      },
      "customer-route": {
        "ClusterId": "customer-cluster",
        "Match": { "Path": "/api/customers/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/customers" }]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/orders" }]
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/products" }]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/notifications" }]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://identity-service:5001/" }
        }
      },
      "customer-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://customer-service:5002/" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://order-service:5003/" }
        }
      },
      "product-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://product-service:5004/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://notification-service:5005/" }
        }
      }
    }
  }
}
